
{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../",
  "testEnvironment": "node",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^generated/prisma/client$": "<rootDir>/generated/prisma/client"
  },
  "transformIgnorePatterns": [
    "/node_modules/(?!(uuid)/)"
  ]
}